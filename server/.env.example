PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/quizz-lear
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d

# CORS — browser origin(s) for the SPA (comma-separated)
# Local:
CLIENT_ORIGIN=http://localhost:5173
# Render + Vercel (use your exact Vercel URL(s), or allow all Vercel previews):
# CLIENT_ORIGIN=https://quizz-lear-8k3t.vercel.app,https://quizz-lear.vercel.app,*.vercel.app

# OTP
OTP_EXPIRES_MINUTES=10
OTP_STICKY_DAYS=3650

# SMTP (optional — OTP logged to console if unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@lear.com

# Seed admin email (must be @lear.com)
ADMIN_EMAIL=admin@lear.com
